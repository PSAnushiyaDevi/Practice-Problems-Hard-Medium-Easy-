class Solution {
    public int islandPerimeter(int[][] grid) {
        int il=0;
        int ne=0;
        for(int i=0;i<grid.length;i++){
            for(int j=0;j<grid[i].length;j++){
                if(grid[i][j]==1){
                    il++;
                    if(i<grid.length-1 && grid[i+1][j]==1){
                        ne++;
                    }
                    if(j<grid[i].length-1 && grid[i][j+1]==1){
                        ne++;
                    }
                }
                
            }
        }
        return il*4-ne*2;
    }
}
