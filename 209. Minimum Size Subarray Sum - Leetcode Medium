class Solution {
    public int minSubArrayLen(int target, int[] nums) {
        int curr=0;
        int left=0;
        int minlen=Integer.MAX_VALUE;
        for(int i=0;i<nums.length;i++){
            curr+=nums[i];
            if(curr>=target){
                while(curr-nums[left]>=target){
                    curr-=nums[left];
                    left++;
                }
                minlen=Math.min(minlen,i-left+1);
            }
        }
        return (minlen==Integer.MAX_VALUE)?0:minlen;
    }
}
