class Solution {
    public int trap(int[] height) {
		int l=0;
		int r=height.length-1;
		int leftmax=0;
		int rightmax=0;
		int t=0;
		while(l<r){
		    leftmax=Math.max(leftmax,height[l]);
		    rightmax=Math.max(rightmax,height[r]);
		    int water=Math.min(leftmax,rightmax);
		    if(height[l]<height[r]){
		        t+=water-height[l];
		        l++;
		        
		    }
		    else{
		        t+=water-height[r];
		        r--;
		        
		    }
		}
		return t;
    }
}
