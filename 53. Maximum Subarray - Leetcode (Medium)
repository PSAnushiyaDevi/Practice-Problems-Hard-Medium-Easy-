class Solution {
    public int maxSubArray(int[] nums) {
        int currentSum=nums[0];
        int Maxsum=nums[0];
        for(int i=1;i<nums.length;i++){
            currentSum=Math.max(currentSum,0)+nums[i];
            Maxsum=Math.max(currentSum,Maxsum);
        }
        return Maxsum;
    }
}
