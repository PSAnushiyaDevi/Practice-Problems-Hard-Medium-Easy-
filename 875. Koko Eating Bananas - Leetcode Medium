class Solution {
    public int minEatingSpeed(int[] piles, int h) {
        int l=1;
        int r=1000000000;
        while(l<=r){
            int mid=l+(r-l)/2;
            if(caneat(piles,mid,h)){
                r=mid-1;
            }
            else{
                l=mid+1;
            }
        }
        return l;
    }
    public boolean caneat(int[] piles,int k,int h){
        long ho=0;
        for(int p:piles){
            int d=p/k;
            ho+=d;
            if(p%k!=0) ho++;
        }
        return ho<=h; 
    }
}
