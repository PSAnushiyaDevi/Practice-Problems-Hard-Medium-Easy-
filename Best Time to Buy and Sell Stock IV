class Solution {
    public int maxProfit(int k, int[] prices) {
        int[] profit=new int[k+1];
        int[] buy=new int[k+1];
        for(int i=0;i<=k;i++){
            buy[i]=Integer.MAX_VALUE;
        }
        for(int price:prices){
            for(int i=1;i<=k;i++){
                buy[i]=Math.min(buy[i],price-profit[i-1]);
                profit[i]=Math.max(profit[i],price-buy[i]);
            }
        }
        return profit[k];
    }
}
