class Solution {
    public int shipWithinDays(int[] weights, int days) {
        int l=0;
        int r=0;
        for(int w:weights){
            l=Math.max(l,w);
            r+=w;
        }
        
        while(l<=r){
            int mid=l+(r-l)/2;
            if(wp(weights,mid,days)){
                r=mid-1;
            }
            else{
                l=mid+1;
            }
        }
        return l;
    }
    public boolean wp(int[] weights, int k, int days){
        int cw=0;
        int daysn=1;
        for(int w:weights){
            if(w>k){
                return false;
            } 
            if(cw+w>k){
                daysn++;
                cw=w;
            }else{
                cw+=w;
            }
        }
        return daysn<=days;
    }
}
