class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int current=0;
        for(int i=0;i<k;i++){
            current+=nums[i];
        }
        double maxavg=(double)current/k;
        
        for(int i=k;i<nums.length;i++){
            current+=nums[i]-nums[i-k];
            maxavg= Math.max(maxavg,(double)current/k);
        }
        return maxavg;
    }
}
